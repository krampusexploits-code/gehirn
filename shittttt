using System;
using System.Collections.Generic;
using System.IO;
using System.Linq;
using System.Reflection;
using System.Text;
using System.Text.Json;
using Mono.Cecil;
using Mono.Cecil.Cil;

//
// A comprehensive .NET assembly obfuscator.
//
// This console program reads a JSON configuration file that specifies the input assembly,
// output path, exclusion patterns, enabled transformation passes and an optional seed for
// deterministic name generation. The obfuscator performs multiple transformations to
// increase reverse engineering resistance while preserving public APIs and interop
// requirements. Each pass can be independently enabled or disabled. After the
// transformations are applied, the tool can optionally execute a smoke‑test method
// specified in the configuration using a fresh AssemblyLoadContext to ensure the
// obfuscated assembly still behaves correctly.
//
// Major transformations include:
//  * Rename obfuscation – rename non‑public types, methods, fields and properties
//    to meaningless identifiers. Identifiers are deterministic given the same
//    random seed. Members marked with attributes like SerializeField or DllImport,
//    or names matching user provided exclusion patterns are left untouched.
//  * Control flow obfuscation – optionally flatten method bodies into a state
//    machine implemented with a dispatcher loop and switch statement. To maintain
//    verifiable IL the implementation avoids tampering with exception handlers and
//    leaves complex flow structures untouched. Additionally, opaque predicates are
//    injected at the beginning of methods to confuse decompilers.
//  * String encryption – replace all string literals with calls to a runtime
//    decryption stub. Strings are XOR‑encrypted with a key derived from the
//    assembly’s MVID and a user provided seed. A static cache ensures each string
//    is decrypted only once at runtime.
//  * Constant obfuscation – rewrite numeric constants into equivalent arithmetic
//    expressions such as `(value + rnd) - rnd` which evaluate to the same result at
//    runtime. This deters straightforward pattern matching on constants.
//  * Metadata obfuscation – strip debug symbols, remove PDB references, randomise
//    the ordering of types and members within metadata tables and remove common
//    descriptive assembly attributes like AssemblyTitle and AssemblyDescription.
//  * Anti‑decompiler injection – insert unreachable instructions with balanced
//    stack usage to deliberately mislead decompilers without violating ECMA‑335
//    requirements. For example, an always‑taken branch skips over a block that
//    pushes and pops a value from the stack. The runtime never executes this
//    dummy code but many decompilers will still attempt to decompile it.
//
// The tool uses Mono.Cecil to read and manipulate the assembly. Cecil exposes
// metadata tokens so that simply changing the Name property of definitions is
// sufficient for renaming; references are automatically updated as noted by
// community guidance【759408141996310†L115-L124】. Control flow flattening is
// inspired by the state machine flattening technique described in
// reverse‑engineering literature【947098854075956†L98-L106】【947098854075956†L109-L143】.
// String encryption follows the concept of assigning each string a unique key,
// storing the encrypted bytes in a data blob and exposing a universal
// decryption method【846784584722526†L28-L68】. Constant obfuscation is motivated
// by the ByteHide ‘Constant Disintegration’ protection which replaces numeric
// constants with expressions evaluating to the same value【249665806828484†L155-L165】.
// Removing PDB symbols is important because PDB files map compiled code back to
// source and should not be deployed with production binaries【491250536690664†L146-L155】.

namespace Obfuscator
{
    /// <summary>
    /// Configuration root corresponding to the JSON file consumed by the obfuscator.
    /// </summary>
    public class ObfuscationConfig
    {
        public string InputAssembly { get; set; } = string.Empty;
        public string OutputAssembly { get; set; } = string.Empty;
        public List<string> ExclusionList { get; set; } = new List<string>();
        public EnabledPasses Passes { get; set; } = new EnabledPasses();
        public string EncryptionSeed { get; set; } = string.Empty;
        public string SmokeTestMethod { get; set; } = string.Empty;
    }

    /// <summary>
    /// Structure representing which passes are enabled. Each property can
    /// independently enable or disable a transformation stage.
    /// </summary>
    public class EnabledPasses
    {
        public bool Rename { get; set; } = true;
        public bool ControlFlow { get; set; } = true;
        public bool StringEncryption { get; set; } = true;
        public bool ConstantObfuscation { get; set; } = true;
        public bool MetadataObfuscation { get; set; } = true;
        public bool AntiDecompiler { get; set; } = true;
    }

    /// <summary>
    /// The main program orchestrates the obfuscation passes and writes the
    /// modified assembly. Use --config path/to/config.json to specify the
    /// configuration file.
    /// </summary>
    internal static class Program
    {
        static int Main(string[] args)
        {
            if (args.Length == 0 || args.Contains("--help") || args.Contains("-h"))
            {
                Console.WriteLine("Usage: dotnet run --config <config.json>");
                return 1;
            }

            string? configPath = null;
            for (int i = 0; i < args.Length - 1; i++)
            {
                if (args[i] == "--config")
                {
                    configPath = args[i + 1];
                }
            }
            if (string.IsNullOrEmpty(configPath))
            {
                Console.Error.WriteLine("Configuration file path must be provided with --config");
                return 1;
            }
            if (!File.Exists(configPath))
            {
                Console.Error.WriteLine($"Configuration file not found: {configPath}");
                return 1;
            }
            var config = JsonSerializer.Deserialize<ObfuscationConfig>(File.ReadAllText(configPath));
            if (config == null)
            {
                Console.Error.WriteLine("Failed to parse configuration file");
                return 1;
            }

            var logger = new TransformationLogger();
            try
            {
                var obfuscator = new ObfuscationPipeline(config, logger);
                obfuscator.Execute();
            }
            catch (Exception ex)
            {
                Console.Error.WriteLine($"Obfuscation failed: {ex}");
                return 1;
            }
            // Write log at the end
            File.WriteAllLines(Path.ChangeExtension(config.OutputAssembly, ".obfuscation.log"), logger.Entries);
            Console.WriteLine("Obfuscation complete.");
            return 0;
        }
    }

    /// <summary>
    /// Collects messages from obfuscation passes. The log is written to a file
    /// alongside the output assembly after all passes complete.
    /// </summary>
    public class TransformationLogger
    {
        private readonly List<string> _entries = new();
        public void Log(string message)
        {
            _entries.Add($"[{DateTime.UtcNow:O}] {message}");
        }
        public IReadOnlyList<string> Entries => _entries;
    }

    /// <summary>
    /// Encapsulates the complete obfuscation pipeline. Each transformation
    /// registers itself with the pipeline and is executed in order. After
    /// applying transformations, the pipeline optionally performs a smoke test.
    /// </summary>
    public class ObfuscationPipeline
    {
        private readonly ObfuscationConfig _config;
        private readonly TransformationLogger _logger;
        private readonly Random _random;

        public ObfuscationPipeline(ObfuscationConfig config, TransformationLogger logger)
        {
            _config = config;
            _logger = logger;
            // Derive a deterministic random seed from the config
            int seed;
            if (!string.IsNullOrEmpty(config.EncryptionSeed))
            {
                unchecked
                {
                    seed = config.EncryptionSeed.Aggregate(0, (s, c) => (s * 31) ^ c);
                }
            }
            else
            {
                seed = Environment.TickCount;
            }
            _random = new Random(seed);
        }

        /// <summary>
        /// Executes all enabled passes. Writes the modified assembly to the
        /// configured output path. Runs optional smoke test afterwards.
        /// </summary>
        public void Execute()
        {
            if (string.IsNullOrEmpty(_config.InputAssembly) || string.IsNullOrEmpty(_config.OutputAssembly))
            {
                throw new InvalidOperationException("InputAssembly and OutputAssembly must be specified");
            }
            if (!File.Exists(_config.InputAssembly))
            {
                throw new FileNotFoundException("Input assembly not found", _config.InputAssembly);
            }

            // Read assembly with symbols if present. Disable reading symbols for metadata obfuscation later.
            var readerParams = new ReaderParameters
            {
                ReadWrite = true,
                ReadSymbols = true,
            };
            var assembly = AssemblyDefinition.ReadAssembly(_config.InputAssembly, readerParams);
            var module = assembly.MainModule;

            // Apply passes in order: rename, control flow, string encryption, constant obfuscation,
            // metadata obfuscation, anti decompiler.
            if (_config.Passes.Rename)
            {
                var renamer = new RenamePass(_config, _logger, _random);
                renamer.Apply(module);
            }
            if (_config.Passes.ControlFlow)
            {
                var cflow = new ControlFlowPass(_config, _logger, _random);
                cflow.Apply(module);
            }
            if (_config.Passes.StringEncryption)
            {
                var strEnc = new StringEncryptionPass(_config, _logger, _random);
                strEnc.Apply(module);
            }
            if (_config.Passes.ConstantObfuscation)
            {
                var constPass = new ConstantObfuscationPass(_config, _logger, _random);
                constPass.Apply(module);
            }
            if (_config.Passes.MetadataObfuscation)
            {
                var meta = new MetadataObfuscationPass(_config, _logger, _random);
                meta.Apply(module);
            }
            if (_config.Passes.AntiDecompiler)
            {
                var anti = new AntiDecompilerPass(_config, _logger, _random);
                anti.Apply(module);
            }

            // Write assembly. Always disable symbol writing for obfuscated output.
            var writerParams = new WriterParameters
            {
                WriteSymbols = false
            };
            assembly.Write(_config.OutputAssembly, writerParams);
            _logger.Log($"Wrote obfuscated assembly to {_config.OutputAssembly}");

            // Run smoke test if configured
            if (!string.IsNullOrEmpty(_config.SmokeTestMethod))
            {
                RunSmokeTest(_config.OutputAssembly, _config.SmokeTestMethod);
            }
        }

        /// <summary>
        /// Invokes a user specified method in a new AssemblyLoadContext to
        /// verify that the obfuscated assembly still works. The method must be
        /// static and parameterless. Any exception thrown by the method
        /// indicates a failed smoke test.
        /// </summary>
        private void RunSmokeTest(string assemblyPath, string methodDescriptor)
        {
            try
            {
                // The descriptor format is Namespace.Type::Method
                var parts = methodDescriptor.Split("::", StringSplitOptions.RemoveEmptyEntries);
                if (parts.Length != 2)
                {
                    _logger.Log($"Invalid SmokeTestMethod format: {methodDescriptor}");
                    return;
                }
                var typeName = parts[0];
                var methodName = parts[1];
                // Load assembly into isolated context
                var alc = new System.Runtime.Loader.AssemblyLoadContext("SmokeTest", isCollectible: true);
                var asm = alc.LoadFromAssemblyPath(Path.GetFullPath(assemblyPath));
                var type = asm.GetType(typeName);
                if (type == null)
                {
                    _logger.Log($"Smoke test failed: type {typeName} not found in obfuscated assembly");
                    return;
                }
                var method = type.GetMethod(methodName, BindingFlags.Public | BindingFlags.NonPublic | BindingFlags.Static);
                if (method == null)
                {
                    _logger.Log($"Smoke test failed: method {methodName} not found on type {typeName}");
                    return;
                }
                if (method.GetParameters().Length != 0)
                {
                    _logger.Log($"Smoke test method must be parameterless: {methodDescriptor}");
                    return;
                }
                // Invoke method
                method.Invoke(null, null);
                _logger.Log($"Smoke test {methodDescriptor} executed successfully");
                // Unload
                alc.Unload();
            }
            catch (Exception ex)
            {
                _logger.Log($"Smoke test {methodDescriptor} threw exception: {ex}");
            }
        }
    }

    /// <summary>
    /// Pass to obfuscate names of non‑public types, methods, fields and properties.
    /// Uses a deterministic random generator seeded from the configuration to
    /// generate unique identifiers. Exclusion patterns prevent renaming of
    /// reflection accessible members or those marked with interop attributes.
    /// </summary>
    internal class RenamePass
    {
        private readonly ObfuscationConfig _config;
        private readonly TransformationLogger _logger;
        private readonly Random _random;
        private int _nameCounter;

        private readonly List<System.Text.RegularExpressions.Regex> _exclusionRegexes;

        public RenamePass(ObfuscationConfig config, TransformationLogger logger, Random random)
        {
            _config = config;
            _logger = logger;
            _random = random;
            _nameCounter = 0;
            _exclusionRegexes = _config.ExclusionList
                .Select(pattern => new System.Text.RegularExpressions.Regex(pattern))
                .ToList();
        }

        public void Apply(ModuleDefinition module)
        {
            // Build list of members to rename. We must rename types before
            // renaming their members to avoid name clashes in nested scopes.
            foreach (var type in module.Types.ToList())
            {
                RenameTypeRecursively(type);
            }
        }

        private void RenameTypeRecursively(TypeDefinition type)
        {
            // Skip the special <Module> type which represents module metadata
            if (type.Name == "<Module>")
                return;

            // First rename nested types
            foreach (var nested in type.NestedTypes)
            {
                RenameTypeRecursively(nested);
            }

            // Decide whether to rename this type
            if (!type.IsPublic && !type.IsNestedPublic)
            {
                if (!IsExcluded(type))
                {
                    var newName = GenerateName();
                    _logger.Log($"Renaming type {type.FullName} -> {newName}");
                    type.Name = newName;
                }
            }
            // Rename fields
            foreach (var field in type.Fields)
            {
                RenameField(field);
            }
            // Rename properties and their accessor methods
            foreach (var prop in type.Properties)
            {
                RenameProperty(prop);
            }
            // Rename events and their accessor methods
            foreach (var ev in type.Events)
            {
                RenameEvent(ev);
            }
            // Rename methods after properties/events to ensure accessors are handled
            foreach (var method in type.Methods)
            {
                RenameMethod(method);
            }
        }

        private void RenameField(FieldDefinition field)
        {
            // Only rename non‑public instance or static fields
            if (field.IsPublic || field.IsFamily || field.IsFamilyOrAssembly)
                return;
            // Do not rename fields that are marked with SerializeField, DllImport, MarshalAs or Obfuscation attributes
            if (HasInteropAttribute(field.CustomAttributes))
                return;
            if (IsExcluded(field))
                return;
            var newName = GenerateName();
            _logger.Log($"Renaming field {field.FullName} -> {newName}");
            field.Name = newName;
        }

        private void RenameProperty(PropertyDefinition prop)
        {
            // Only rename non‑public properties
            var getMethod = prop.GetMethod;
            var setMethod = prop.SetMethod;
            bool isPublic = (getMethod != null && (getMethod.IsPublic || getMethod.IsFamily || getMethod.IsFamilyOrAssembly)) ||
                            (setMethod != null && (setMethod.IsPublic || setMethod.IsFamily || setMethod.IsFamilyOrAssembly));
            if (isPublic)
                return;
            if (IsExcluded(prop))
                return;
            var newName = GenerateName();
            _logger.Log($"Renaming property {prop.FullName} -> {newName}");
            // Rename property and update accessor names accordingly
            prop.Name = newName;
            if (getMethod != null)
            {
                getMethod.Name = $"get_{newName}";
            }
            if (setMethod != null)
            {
                setMethod.Name = $"set_{newName}";
            }
        }

        private void RenameEvent(EventDefinition ev)
        {
            // Only rename non‑public events
            var addMethod = ev.AddMethod;
            var removeMethod = ev.RemoveMethod;
            bool isPublic = (addMethod != null && (addMethod.IsPublic || addMethod.IsFamily || addMethod.IsFamilyOrAssembly)) ||
                            (removeMethod != null && (removeMethod.IsPublic || removeMethod.IsFamily || removeMethod.IsFamilyOrAssembly));
            if (isPublic)
                return;
            if (IsExcluded(ev))
                return;
            var newName = GenerateName();
            _logger.Log($"Renaming event {ev.FullName} -> {newName}");
            ev.Name = newName;
            if (addMethod != null)
            {
                addMethod.Name = $"add_{newName}";
            }
            if (removeMethod != null)
            {
                removeMethod.Name = $"remove_{newName}";
            }
        }

        private void RenameMethod(MethodDefinition method)
        {
            // Only rename non‑public methods; skip constructors
            if (method.IsConstructor || method.IsPublic || method.IsFamily || method.IsFamilyOrAssembly)
                return;
            // Do not rename methods implementing interface or overriding base
            if (method.IsVirtual && (method.IsReuseSlot || method.Overrides.Count > 0))
                return;
            // Do not rename PInvoke methods
            if (method.IsPInvokeImpl)
                return;
            // Skip property/event accessors – renamed as part of property/event rename
            if (method.SemanticsAttributes != 0)
                return;
            if (IsExcluded(method))
                return;
            var newName = GenerateName();
            _logger.Log($"Renaming method {method.FullName} -> {newName}");
            method.Name = newName;
            // Note: parameter names are not meaningful for execution and usually stripped in release builds,
            // so we do not rename them here.
        }

        private bool HasInteropAttribute(IEnumerable<CustomAttribute> attributes)
        {
            foreach (var ca in attributes)
            {
                var name = ca.AttributeType.FullName;
                if (name == "System.Runtime.InteropServices.DllImportAttribute" ||
                    name == "System.Runtime.InteropServices.MarshalAsAttribute" ||
                    name == "System.NonSerializedAttribute" ||
                    name == "UnityEngine.SerializeField" ||
                    name == "System.Reflection.ObfuscationAttribute")
                {
                    return true;
                }
            }
            return false;
        }

        private bool IsExcluded(IMemberDefinition member)
        {
            // Build fully qualified name (namespace + type + member)
            string fullName = member.FullName;
            foreach (var regex in _exclusionRegexes)
            {
                if (regex.IsMatch(fullName))
                    return true;
            }
            return false;
        }

        private string GenerateName()
        {
            // Generate a short base36 identifier using the counter
            int value = _nameCounter++;
            const string alphabet = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789";
            if (value == 0)
                return alphabet[0].ToString();
            var sb = new StringBuilder();
            int baseLen = alphabet.Length;
            while (value > 0)
            {
                sb.Insert(0, alphabet[value % baseLen]);
                value /= baseLen;
            }
            return sb.ToString();
        }
    }

    /// <summary>
    /// Pass to flatten control flow and insert opaque predicates. This
    /// implementation performs conservative flattening on methods without
    /// exception handlers and without complex branching (e.g., switch or leave
    /// instructions). For methods that cannot be flattened safely, only opaque
    /// predicates are injected. The flattening technique is inspired by
    /// dispatcher loop control flow flattening【947098854075956†L98-L106】.
    /// </summary>
    internal class ControlFlowPass
    {
        private readonly ObfuscationConfig _config;
        private readonly TransformationLogger _logger;
        private readonly Random _random;

        public ControlFlowPass(ObfuscationConfig config, TransformationLogger logger, Random random)
        {
            _config = config;
            _logger = logger;
            _random = random;
        }

        public void Apply(ModuleDefinition module)
        {
            foreach (var type in module.Types)
            {
                ProcessType(type);
            }
        }

        private void ProcessType(TypeDefinition type)
        {
            foreach (var method in type.Methods)
            {
                if (!method.HasBody)
                    continue;
                // Insert an opaque predicate at the beginning of each method
                InsertOpaquePredicate(method);
                // Attempt to flatten control flow if safe
                TryFlatten(method);
            }
            foreach (var nested in type.NestedTypes)
            {
                ProcessType(nested);
            }
        }

        /// <summary>
        /// Inserts a simple opaque predicate that is always true and contains
        /// unreachable code. The inserted instructions balance the stack to
        /// maintain verifiable IL.
        /// </summary>
        private void InsertOpaquePredicate(MethodDefinition method)
        {
            var body = method.Body;
            var il = body.GetILProcessor();
            var first = body.Instructions.First();
            // Construct the following sequence:
            // ldc.i4.0
            // br.s skip
            // ldc.i4.1
            // pop
            // skip:
            var skip = Instruction.Create(OpCodes.Nop);
            var seq = new[]
            {
                Instruction.Create(OpCodes.Ldc_I4_0),
                Instruction.Create(OpCodes.Br_S, skip),
                Instruction.Create(OpCodes.Ldc_I4_1),
                Instruction.Create(OpCodes.Pop),
                skip
            };
            foreach (var instr in seq.Reverse())
            {
                il.InsertBefore(first, instr);
            }
            _logger.Log($"Inserted opaque predicate in {method.FullName}");
        }

        /// <summary>
        /// Attempts to flatten the method body into a state machine dispatcher
        /// pattern. If the method contains exception handlers, switch
        /// instructions or leave instructions, the method is left unmodified.
        /// </summary>
        private void TryFlatten(MethodDefinition method)
        {
            var body = method.Body;
            // Skip flattening for methods with exception handlers or empty bodies
            if (!body.HasExceptionHandlers && body.Instructions.Count > 10)
            {
                // Quick scan to see if method contains opcodes we do not handle
                bool canFlatten = true;
                foreach (var instr in body.Instructions)
                {
                    if (instr.OpCode.FlowControl == FlowControl.Throw ||
                        instr.OpCode.Code == Code.Switch ||
                        instr.OpCode.Code == Code.Leave ||
                        instr.OpCode.Code == Code.Leave_S)
                    {
                        canFlatten = false;
                        break;
                    }
                }
                if (canFlatten)
                {
                    try
                    {
                        FlattenMethod(method);
                        _logger.Log($"Flattened control flow in {method.FullName}");
                    }
                    catch (Exception ex)
                    {
                        // If flattening fails, leave the method untouched and log the reason
                        _logger.Log($"Failed to flatten {method.FullName}: {ex.Message}");
                    }
                }
            }
        }

        /// <summary>
        /// Performs control flow flattening by transforming the method into a
        /// state machine. Only basic branch opcodes (br, brtrue, brfalse) are
        /// supported. The resulting IL uses a local state variable and a
        /// dispatcher loop with a switch statement.
        /// </summary>
        private void FlattenMethod(MethodDefinition method)
        {
            var body = method.Body;
            var il = body.GetILProcessor();
            var originalInstructions = body.Instructions.ToList();
            // Analyse basic blocks
            var blocks = BuildBasicBlocks(originalInstructions, out var blockMap);
            if (blocks.Count < 2)
            {
                // Nothing to flatten
                return;
            }
            // Determine transitions for each block
            var transitions = new List<BlockTransition>();
            foreach (var block in blocks)
            {
                transitions.Add(AnalyseBlockTransition(block, blockMap, blocks));
            }
            // Setup new body
            body.Variables.Add(new VariableDefinition(method.Module.TypeSystem.Int32)); // stateVar at last index
            int stateVarIndex = body.Variables.Count - 1;
            body.InitLocals = true;
            body.Instructions.Clear();
            var switchTargets = new Instruction[blocks.Count];
            // Create placeholder targets for each state
            for (int i = 0; i < blocks.Count; i++)
            {
                switchTargets[i] = Instruction.Create(OpCodes.Nop);
            }
            // Instruction list
            var instrs = new List<Instruction>();
            // Initialise state variable to 0
            instrs.Add(Instruction.Create(OpCodes.Ldc_I4_0));
            instrs.Add(Instruction.Create(OpCodes.Stloc, stateVarIndex));
            // Start of dispatcher loop
            var loopStart = Instruction.Create(OpCodes.Nop);
            instrs.Add(loopStart);
            // Load state and switch
            instrs.Add(Instruction.Create(OpCodes.Ldloc, stateVarIndex));
            var switchInstr = Instruction.Create(OpCodes.Switch, switchTargets);
            instrs.Add(switchInstr);
            // Default case: break out of loop (for state outside range)
            var breakInstr = Instruction.Create(OpCodes.Br, Instruction.Create(OpCodes.Ret));
            instrs.Add(breakInstr);
            // Append case bodies
            var caseBodies = new List<List<Instruction>>(blocks.Count);
            for (int i = 0; i < blocks.Count; i++)
            {
                var caseInstrs = new List<Instruction>();
                // Mark the target
                caseInstrs.Add(switchTargets[i]);
                // Copy original instructions except branch
                foreach (var orig in blocks[i].Instructions)
                {
                    if (IsBranchInstruction(orig))
                    {
                        // We'll handle transitions separately
                        break;
                    }
                    caseInstrs.Add(CloneInstruction(orig, method, stateVarIndex));
                }
                // Append transition
                var trans = transitions[i];
                BuildTransition(il, caseInstrs, trans, stateVarIndex, loopStart);
                caseBodies.Add(caseInstrs);
            }
            // Add all case bodies to the instruction list
            foreach (var caseInstrs in caseBodies)
            {
                instrs.AddRange(caseInstrs);
            }
            // Append final return (default path)
            instrs.Add(Instruction.Create(OpCodes.Ret));
            // Now replace method body
            body.Instructions.Clear();
            foreach (var instr in instrs)
            {
                body.Instructions.Add(instr);
            }
        }

        private static bool IsBranchInstruction(Instruction instr)
        {
            return instr.OpCode.FlowControl == FlowControl.Branch || instr.OpCode.FlowControl == FlowControl.Cond_Branch;
        }

        /// <summary>
        /// Clones a single instruction. For most instructions the operand can be reused.
        /// </summary>
        private static Instruction CloneInstruction(Instruction orig, MethodDefinition context, int stateVarIndex)
        {
            // For simplicity we do not deep clone branch targets here because
            // branch instructions are excluded from cloning in FlattenMethod. Other
            // instructions can be reused as is. For call instructions referencing
            // member definitions, the operand is reused. If the operand is a
            // parameter or variable, update variable index if necessary.
            if (orig.Operand is ParameterDefinition param)
            {
                return Instruction.Create(orig.OpCode, param);
            }
            else if (orig.Operand is VariableDefinition var)
            {
                return Instruction.Create(orig.OpCode, var);
            }
            else if (orig.Operand == null)
            {
                return Instruction.Create(orig.OpCode);
            }
            else
            {
                return Instruction.Create(orig.OpCode, orig.Operand);
            }
        }

        /// <summary>
        /// Represents a basic block: a contiguous sequence of instructions without
        /// internal jumps. The LastInstruction is the branch instruction (if any).
        /// </summary>
        private class BasicBlock
