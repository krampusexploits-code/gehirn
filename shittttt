        private int ObfuscateConstants(TypeDefinition type)
        {
            int count = 0;
            foreach (var method in type.Methods)
            {
                if (!method.HasBody) continue;
                var il = method.Body.GetILProcessor();
                for (int i = 0; i < method.Body.Instructions.Count; i++)
                {
                    var instr = method.Body.Instructions[i];
                    if (instr.OpCode.Code == Code.Ldc_I4 || instr.OpCode.Code == Code.Ldc_I4_S)
                    {
                        int value = instr.OpCode.Code == Code.Ldc_I4_S ? (sbyte)instr.Operand : (int)instr.Operand;
                        // Skip small constants (0, 1) to keep IL compact
                        if (value == 0 || value == 1) continue;
                        // Build expression (value + rnd) - rnd
                        int rnd = _random.Next(2, 16);
                        var newInstrs = new List<Instruction>
                        {
                            Instruction.Create(OpCodes.Ldc_I4, value + rnd),
                            Instruction.Create(OpCodes.Ldc_I4, rnd),
                            Instruction.Create(OpCodes.Sub)
                        };
                        il.Replace(instr, newInstrs[0]);
                        il.InsertAfter(newInstrs[0], newInstrs[1]);
                        il.InsertAfter(newInstrs[1], newInstrs[2]);
                        count++;
                    }
                    else if (instr.OpCode.Code == Code.Ldc_R4)
                    {
                        float value = (float)instr.Operand;
                        // Represent as (value * 1.0f) + 0.0f
                        var newInstrs = new List<Instruction>
                        {
                            Instruction.Create(OpCodes.Ldc_R4, value),
                            Instruction.Create(OpCodes.Ldc_R4, 1.0f),
                            Instruction.Create(OpCodes.Mul),
                            Instruction.Create(OpCodes.Ldc_R4, 0.0f),
                            Instruction.Create(OpCodes.Add)
                        };
                        il.Replace(instr, newInstrs[0]);
                        il.InsertAfter(newInstrs[0], newInstrs[1]);
                        il.InsertAfter(newInstrs[1], newInstrs[2]);
                        il.InsertAfter(newInstrs[2], newInstrs[3]);
                        il.InsertAfter(newInstrs[3], newInstrs[4]);
                        count++;
                    }
                }
            }
            foreach (var nested in type.NestedTypes)
            {
                count += ObfuscateConstants(nested);
            }
            return count;
        }
    }

