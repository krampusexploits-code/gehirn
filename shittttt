        /// <summary>
        /// Describes how to transition from a block: for unconditional or
        /// conditional jumps, the next state(s) are recorded. For return
        /// instructions, state is set to -1.
        /// </summary>
        private record BlockTransition
        {
            public int BlockIndex;
            public TransitionKind Kind;
            public int TrueState;
            public int FalseState;
            public Instruction OriginalBranch;
        }

        private enum TransitionKind { None, Unconditional, Conditional, Return }

        private static List<BasicBlock> BuildBasicBlocks(List<Instruction> instructions, out Dictionary<Instruction, int> blockMap)
        {
            blockMap = new Dictionary<Instruction, int>();
            var starts = new HashSet<Instruction>();
            if (instructions.Count > 0)
                starts.Add(instructions[0]);
            // Determine block starts based on branch targets and fallthrough
            foreach (var instr in instructions)
            {
                if (instr.OpCode.FlowControl == FlowControl.Branch || instr.OpCode.FlowControl == FlowControl.Cond_Branch)
                {
                    if (instr.Operand is Instruction target)
                    {
                        starts.Add(target);
                        // next instruction after a branch also starts a block
                        var next = instr.Next;
                        if (next != null)
                            starts.Add(next);
                    }
                }
                else if (instr.OpCode.FlowControl == FlowControl.Return)
                {
                    var next = instr.Next;
                    if (next != null)
                        starts.Add(next);
                }
            }
            // Build blocks
            var sortedStarts = instructions.Where(i => starts.Contains(i)).ToList();
            var blocks = new List<BasicBlock>();
            for (int i = 0; i < sortedStarts.Count; i++)
            {
                var start = sortedStarts[i];
                var block = new BasicBlock { Index = blocks.Count };
                var current = start;
                while (current != null)
                {
                    block.Instructions.Add(current);
                    // Break if next is a start of another block
                    var next = current.Next;
                    if (next == null || starts.Contains(next))
                        break;
                    current = next;
                }
                blocks.Add(block);
            }
            // Fill blockMap for branch target resolution
            foreach (var block in blocks)
            {
                blockMap[block.Instructions[0]] = block.Index;
            }
            return blocks;
        }

        private static BlockTransition AnalyseBlockTransition(BasicBlock block, Dictionary<Instruction, int> blockMap, List<BasicBlock> blocks)
        {
            var lastInstr = block.Instructions.Last();
            if (lastInstr.OpCode.FlowControl == FlowControl.Return)
            {
                return new BlockTransition { BlockIndex = block.Index, Kind = TransitionKind.Return };
            }
            if (lastInstr.OpCode.FlowControl == FlowControl.Branch)
            {
                // Unconditional branch
                int targetState = -1;
                if (lastInstr.Operand is Instruction target && blockMap.TryGetValue(target, out targetState))
                {
                    return new BlockTransition { BlockIndex = block.Index, Kind = TransitionKind.Unconditional, TrueState = targetState, OriginalBranch = lastInstr };
                }
                // Unknown target: treat as return
                return new BlockTransition { BlockIndex = block.Index, Kind = TransitionKind.Return };
            }
            if (lastInstr.OpCode.FlowControl == FlowControl.Cond_Branch)
            {
                // Conditional branch: branch to operand on true; fall through to next block on false
                int trueState = -1;
                int falseState = -1;
                if (lastInstr.Operand is Instruction target && blockMap.TryGetValue(target, out trueState))
                {
                    var nextInstr = lastInstr.Next;
                    if (nextInstr != null && blockMap.TryGetValue(nextInstr, out falseState))
                    {
                        return new BlockTransition
                        {
                            BlockIndex = block.Index,
                            Kind = TransitionKind.Conditional,
                            TrueState = trueState,
                            FalseState = falseState,
                            OriginalBranch = lastInstr
                        };
                    }
                }
                // If we cannot resolve, treat as return
                return new BlockTransition { BlockIndex = block.Index, Kind = TransitionKind.Return };
            }
            // Fallthrough: go to next block if present
            var last = block.Instructions.Last();
            var nextInst = last.Next;
            if (nextInst != null && blockMap.TryGetValue(nextInst, out int fallState))
            {
                return new BlockTransition { BlockIndex = block.Index, Kind = TransitionKind.Unconditional, TrueState = fallState, OriginalBranch = null };
            }
            // Else return
            return new BlockTransition { BlockIndex = block.Index, Kind = TransitionKind.Return };
        }

        private static void BuildTransition(ILProcessor il, List<Instruction> caseInstrs, BlockTransition trans, int stateVarIndex, Instruction loopStart)
        {
            // Append code to set state variable and branch back to loop
            switch (trans.Kind)
            {
                case TransitionKind.Return:
                    // Emit return
                    caseInstrs.Add(Instruction.Create(OpCodes.Ret));
                    break;
                case TransitionKind.Unconditional:
                    // Set state = TrueState; branch to loop start
                    caseInstrs.Add(Instruction.Create(OpCodes.Ldc_I4, trans.TrueState));
                    caseInstrs.Add(Instruction.Create(OpCodes.Stloc, stateVarIndex));
                    caseInstrs.Add(Instruction.Create(OpCodes.Br, loopStart));
                    break;
                case TransitionKind.Conditional:
                    // Evaluate original condition. We clone the original branch
                    // instruction so the condition logic remains the same but redirect the target.
                    var branch = trans.OriginalBranch;
                    // Clone preceding condition instructions if needed – these
                    // instructions are already present in caseInstrs because
                    // BuildBasicBlocks included them. We only need to emit branch.
                    var trueLabel = Instruction.Create(OpCodes.Nop);
                    // Emit conditional branch with original opcode pointing to trueLabel
                    caseInstrs.Add(Instruction.Create(branch.OpCode, trueLabel));
                    // False path: load falseState, stloc, br loopStart
                    caseInstrs.Add(Instruction.Create(OpCodes.Ldc_I4, trans.FalseState));
                    caseInstrs.Add(Instruction.Create(OpCodes.Stloc, stateVarIndex));
                    caseInstrs.Add(Instruction.Create(OpCodes.Br, loopStart));
                    // True label
                    caseInstrs.Add(trueLabel);
                    // True path: load trueState, stloc, br loopStart
                    caseInstrs.Add(Instruction.Create(OpCodes.Ldc_I4, trans.TrueState));
                    caseInstrs.Add(Instruction.Create(OpCodes.Stloc, stateVarIndex));
                    caseInstrs.Add(Instruction.Create(OpCodes.Br, loopStart));
                    break;
            }
        }
    }

