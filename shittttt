            foreach (var t in nonModuleTypes)
            {
                module.Types.Add(t);
            }
            // Randomise members inside each type
            foreach (var type in module.Types)
            {
                Shuffle(type.Fields);
                Shuffle(type.Methods);
                Shuffle(type.Properties);
                Shuffle(type.Events);
            }
            _logger.Log("Randomised metadata order and stripped PDB information");
        }
        private void Shuffle<T>(IList<T> list)
        {
            for (int i = list.Count - 1; i > 0; i--)
            {
                int j = _random.Next(i + 1);
                (list[i], list[j]) = (list[j], list[i]);
            }
        }
    }

    /// <summary>
    /// Inserts legal but confusing IL patterns designed to mislead decompilers.
    /// The dummy instructions are unreachable at runtime but can trip static
    /// analysis. For example, an always‑taken branch skips over a code block
    /// that manipulates the evaluation stack.【947098854075956†L109-L143】
    /// </summary>
    internal class AntiDecompilerPass
    {
        private readonly ObfuscationConfig _config;
        private readonly TransformationLogger _logger;
        private readonly Random _random;
        public AntiDecompilerPass(ObfuscationConfig config, TransformationLogger logger, Random random)
        {
            _config = config;
            _logger = logger;
            _random = random;
        }
        public void Apply(ModuleDefinition module)
        {
            foreach (var type in module.Types)
            {
                ProcessType(type);
            }
        }
        private void ProcessType(TypeDefinition type)
        {
            foreach (var method in type.Methods)
            {
                if (!method.HasBody) continue;
                InsertConfusingSequence(method);
            }
            foreach (var nested in type.NestedTypes)
            {
                ProcessType(nested);
            }
        }
        private void InsertConfusingSequence(MethodDefinition method)
        {
            var il = method.Body.GetILProcessor();
            var first = method.Body.Instructions.First();
            // Sequence:
            // ldstr ""
            // pop
            // ldc.i4.0
            // br.s end
            // ldloc.0 (push local) // may mismatch stack type but unreachable
            // pop
            // end:
            var end = Instruction.Create(OpCodes.Nop);
            var seq = new List<Instruction>
            {
                Instruction.Create(OpCodes.Ldstr, ""),
                Instruction.Create(OpCodes.Pop),
                Instruction.Create(OpCodes.Ldc_I4_0),
                Instruction.Create(OpCodes.Br_S, end),
                Instruction.Create(OpCodes.Ldc_I4_1),
                Instruction.Create(OpCodes.Pop),
                end
            };
            foreach (var instr in seq.Reverse<Instruction>())
            {
                il.InsertBefore(first, instr);
            }
            _logger.Log($"Inserted anti‑decompiler sequence in {method.FullName}");
        }
    }
}
