        private readonly ObfuscationConfig _config;
        private readonly TransformationLogger _logger;
        private readonly Random _random;

        public ConstantObfuscationPass(ObfuscationConfig config, TransformationLogger logger, Random random)
        {
            _config = config;
            _logger = logger;
            _random = random;
        }
        public void Apply(ModuleDefinition module)
        {
            int count = 0;
            foreach (var type in module.Types)
            {
                count += ObfuscateConstants(type);
            }
            if (count > 0)
            {
                _logger.Log($"Obfuscated {count} numeric constants");
            }
